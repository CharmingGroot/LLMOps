{
  "id": "llm-pipeline-001",
  "name": "LLM Training Pipeline",
  "description": "End-to-end LLM text classification training and deployment pipeline",
  "stages": [
    {
      "id": "preprocess",
      "name": "Data Preprocessing",
      "type": "preprocess",
      "module": {
        "type": "python",
        "entrypoint": "modules/preprocess/main.py",
        "args": ["--dataset", "imdb", "--model-name", "distilbert-base-uncased", "--max-samples", "2000", "--max-length", "256", "--output-path", "data/processed"]
      },
      "timeout": 3600000
    },
    {
      "id": "train",
      "name": "Model Training",
      "type": "train",
      "module": {
        "type": "python",
        "entrypoint": "modules/train/main.py",
        "args": ["--data-path", "data/processed", "--model-output", "models/model", "--model-name", "distilbert-base-uncased", "--epochs", "3", "--learning-rate", "2e-5", "--batch-size", "16"]
      },
      "dependencies": ["preprocess"],
      "timeout": 7200000,
      "retryPolicy": {
        "maxRetries": 2,
        "backoff": "exponential",
        "initialDelay": 5000
      }
    },
    {
      "id": "benchmark",
      "name": "Model Benchmark",
      "type": "benchmark",
      "module": {
        "type": "python",
        "entrypoint": "modules/benchmark/main.py",
        "args": ["--model-path", "models/model/best", "--data-path", "data/processed", "--accuracy-threshold", "0.70"]
      },
      "dependencies": ["train"],
      "condition": {
        "field": "accuracy",
        "operator": "gte",
        "value": 0.70
      }
    },
    {
      "id": "deploy",
      "name": "Model Deployment",
      "type": "deploy",
      "module": {
        "type": "python",
        "entrypoint": "modules/deploy/main.py",
        "args": ["--model-path", "models/model/best", "--model-name", "llmops-text-classifier", "--target", "staging"]
      },
      "dependencies": ["benchmark"]
    }
  ],
  "mlflow": {
    "trackingUri": "http://localhost:5000",
    "experimentName": "llm-training",
    "artifactLocation": "s3://mlflow-artifacts/llm"
  }
}
