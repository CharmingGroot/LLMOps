{
  "name": "llmops",
  "version": "0.1.0",
  "private": true,
  "description": "LLMOps Platform - Modular ML Pipeline Orchestration",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "commander": "^14.0.3",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
